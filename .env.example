# ========================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE - DJANGO
# ========================================
#
# Copie este arquivo para ".env" na pasta django_backend/
# e ajuste os valores para produção
#

# Django Secret Key (GERE UMA NOVA!)
# Para gerar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-chave-secreta-super-segura-aqui

# Debug (True para desenvolvimento, False para produção)
DEBUG=False

# Hosts permitidos (separe por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# Banco de dados (opcional - SQLite por padrão)
# Para PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=reconhecimento_facial
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha
# DB_HOST=localhost
# DB_PORT=5432

# Email (opcional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=seu-email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-app
