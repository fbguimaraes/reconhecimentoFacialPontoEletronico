# ========================================
# Sistema de Reconhecimento Facial
# .gitignore
# ========================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.Python

# Ambientes virtuais
env/
venv/
ENV/
env.bak/
venv.bak/

# Django
*.log
db.sqlite3
db.sqlite3-journal
/static/
/staticfiles/
/media/

# PyInstaller
*.manifest
*.spec
build/
dist/
dist_release/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Arquivos de configuração com dados sensíveis
config.ini
*.env
.env.local
.env.*.local

# Dados do sistema
data/
logs/
*.csv
*.pkl
*.pickle

# Modelos treinados (grandes - podem ser baixados)
models/

# Arquivos temporários Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Arquivos de servidor
SERVER_INFO.txt

# Certificados e chaves
*.pem
*.key
*.crt

# Backups
*.bak
*.backup
*.old
